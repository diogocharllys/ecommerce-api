# Conexão com o banco MySQL (Prisma)
# Local:    mysql://root:senha@localhost:3306/ecommercedb
# Produção: use a connection string fornecida pelo provedor (ex.: Railway)
DATABASE_URL="mysql://root:senha@localhost:3306/ecommercedb"

# Segredo usado para assinar os tokens JWT — use um valor longo e aleatório
JWT_SECRET="troque-por-uma-chave-secreta-forte"

# Porta da aplicação (a maioria dos provedores injeta PORT automaticamente)
PORT=3000
